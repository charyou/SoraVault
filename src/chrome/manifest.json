{
  "manifest_version": 3,
  "name": "SoraVault",
  "version": "2.7.2",
  "description": "Bulk backup Sora content — images, videos, drafts, liked content. API-driven, page-independent.",
  "author": "Sebastian Haas (charyou)",
  "homepage_url": "https://github.com/charyou/SoraVault",

  "icons": {
    "16":  "assets/icon16.png",
    "48":  "assets/icon48.png",
    "128": "assets/icon128.png"
  },

  "action": {
    "default_icon": {
      "16":  "assets/icon16.png",
      "48":  "assets/icon48.png",
      "128": "assets/icon128.png"
    },
    "default_title": "SoraVault — open a Sora page to use"
  },

  "content_scripts": [
    {
      "matches": [
        "https://sora.chatgpt.com/*",
        "https://sora.com/*",
        "https://www.sora.com/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": [
        "https://sora.chatgpt.com/*",
        "https://sora.com/*",
        "https://www.sora.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "host_permissions": [
    "https://sora.chatgpt.com/*",
    "https://sora.com/*",
    "https://www.sora.com/*",
    "https://videos.openai.com/*",
    "https://api.github.com/*"
  ],

  "permissions": [
    "downloads",
    "storage"
  ],

  "web_accessible_resources": [
    {
      "resources": ["assets/*", "img/*"],
      "matches": [
        "https://sora.chatgpt.com/*",
        "https://sora.com/*",
        "https://www.sora.com/*"
      ]
    }
  ]
}
